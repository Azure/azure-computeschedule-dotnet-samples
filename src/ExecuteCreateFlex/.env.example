# Azure subscription ID
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Resource group that contains (or will contain) the virtual machines
AZURE_RESOURCE_GROUP=your-resource-group-name

# Azure region for the virtual machines (e.g. eastus2euap, eastus, westeurope)
AZURE_LOCATION=eastus2euap

# VNet and subnet names created in the resource group before VM provisioning
AZURE_VNET_NAME=flex-vnet
AZURE_SUBNET_NAME=flex-subnet

# Prefix used for VM names created by ComputeSchedule
AZURE_VM_PREFIX=sampleflex

# Admin credentials for the provisioned virtual machines
AZURE_VM_ADMIN_USERNAME=your-admin-username
AZURE_VM_ADMIN_PASSWORD=your-strong-password
